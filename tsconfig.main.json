{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": "dist"
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/converter/**/*.ts"
  ],
  "exclude": [
    "src/renderer/**/*",
    "node_modules",
    "dist",
    "out"
  ]
}