{
  "name": "easyfbx2vrma",
  "version": "1.0.0",
  "description": "Easy FBX to VRMA converter with drag and drop support",
  "main": "electron/main.js",
  "type": "commonjs",
  "scripts": {
    "postinstall": "node download-fbx2gltf.js",
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "build:win": "npm run build -- --win",
    "build:mac": "npm run build -- --mac",
    "build:linux": "npm run build -- --linux",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:dev": "set NODE_ENV=development && electron .",
    "electron:dev:unix": "NODE_ENV=development electron .",
    "start": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron:dev\"",
    "compile": "tsc",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "keywords": [
    "fbx",
    "vrma",
    "converter",
    "3d",
    "animation"
  ],
  "author": "EasyFBX2VRMA",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.2.1",
    "concurrently": "^9.2.0",
    "electron": "^37.2.6",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.2",
    "vite": "^7.1.1",
    "wait-on": "^8.0.4"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.4.2",
    "@pixiv/three-vrm-animation": "^3.4.2",
    "three": "^0.179.1"
  }
}
